{
  "expo": {
    "name": "Pokemon Explorer",
    "slug": "pokemon-explorer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "pokemonexplorer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pokemonexplorer.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.pokemonexplorer.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permite que o Pokemon Explorer acesse sua localização.",
          "locationAlwaysAndWhenInUsePermission": "Permite que o Pokemon Explorer acesse sua localização."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
